{
  "name": "docseeker",
  "version": "1.2.0",
  "description": "Personal document search tool with full-text search and scheduled scanning",
  "main": "./out/main/index.js",
  "author": "lzg14",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lzg14/DocSeeker"
  },
  "scripts": {
    "dev": "cross-env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "npx electron-rebuild -f -w better-sqlite3",
    "build:win": "npm run build && electron-builder --win --config",
    "build:win:portable": "npm run build && electron-builder --win portable --config",
    "build:mac": "npm run build && electron-builder --mac --config",
    "build:linux": "npm run build && electron-builder --linux --config"
  },
  "build": {
    "appId": "com.docseeker.app",
    "productName": "DocSeeker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "go/docseeker-monitor",
        "to": "docseeker-monitor",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "lzg14",
      "repo": "DocSeeker"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "electron-log": "^5.2.0",
    "exifr": "^7.1.3",
    "fuse.js": "^7.3.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "mobi": "^0.0.1",
    "music-metadata": "^11.12.3",
    "node-unrar-js": "^1.0.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "pst-extractor": "^1.12.0",
    "tar.gz": "^1.0.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^29.5.0",
    "@types/jszip": "^3.4.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "icon-gen": "^5.0.0",
    "jest": "^29.7.0",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.0"
  }
}
